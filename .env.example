# ── Google OAuth (ログイン + Gmail送信) ──────────────────────────
# Google Cloud Console > APIs & Services > 認証情報 > OAuth 2.0 クライアント
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 本番URLに変更してください (例: https://your-app.example.com)
APP_BASE_URL=http://localhost:8000

# セッション暗号化キー (自動生成されますが、固定する場合は設定)
SESSION_SECRET=

# ── Google Maps API (企業情報取得) ───────────────────────────────
# ※ ユーザーがUIで設定した値が優先されます。フォールバック用。
GOOGLE_MAPS_API_KEY=

# true: 実送信せずログのみ
EMAIL_DRY_RUN=true
FORM_DRY_RUN=true
DAILY_SEND_LIMIT=100

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
CONTACT_FROM_NAME=AutoSales
