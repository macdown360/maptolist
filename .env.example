# ── Google OAuth (ログイン + Gmail送信) ──────────────────────────
# Google Cloud Console > APIs & Services > 認証情報 > OAuth 2.0 クライアント
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 本番URLに変更してください (例: https://your-app.example.com)
APP_BASE_URL=http://localhost:8000

# セッション暗号化キー (自動生成されますが、固定する場合は設定)
SESSION_SECRET=

# true の間は Google ログインを無効化し、ローカルのデモユーザーで利用
DISABLE_GOOGLE_LOGIN=false

# フロント公開元を許可 (カンマ区切り)
# GitHub Pages: https://macdown360.github.io/autosales/ で公開する場合
# CORS_ALLOW_ORIGINS=https://macdown360.github.io
CORS_ALLOW_ORIGINS=

# ── Google Maps API (企業情報取得) ───────────────────────────────
# ※ 公開運用では、各ユーザーがUIで自分のキーを設定して利用します。
#    サーバーの GOOGLE_MAPS_API_KEY は未ログイン用途などの補助用途です。
GOOGLE_MAPS_API_KEY=

# true: 実送信せずログのみ
EMAIL_DRY_RUN=true
FORM_DRY_RUN=true
DAILY_SEND_LIMIT=100

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
CONTACT_FROM_NAME=AutoSales
